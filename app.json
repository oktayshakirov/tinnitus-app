        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "TinnitusCheckin",
              "label": "Journal",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "description": "Your journal streak and today's tinnitus level at a glance.",
              "previewImage": "./assets/images/icon.png",
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "TinnitusCheckinWide",
              "label": "Journal (Wide)",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "description": "Your journal streak, today's level and a 7-day trend.",
              "previewImage": "./assets/images/icon.png",
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "TinnitusTip",
              "label": "Daily Tinnitus Tip",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "description": "A helpful tinnitus tip that changes every day.",
              "previewImage": "./assets/images/icon.png",
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "TinnitusTipWide",
              "label": "Daily Tinnitus Tip (Wide)",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "description": "A helpful tinnitus tip that changes every day.",
              "previewImage": "./assets/images/icon.png",
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "TinnitusSound",
              "label": "Sound of the Day",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "description": "A relaxing sound to listen to, refreshed every day.",
              "previewImage": "./assets/images/icon.png",
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "TinnitusSoundWide",
              "label": "Sound of the Day (Wide)",
              "minWidth": "250dp",
              "minHeight": "110dp",
